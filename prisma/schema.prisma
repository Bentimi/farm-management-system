generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum genderStatus {
    male
    female
    other
}

enum maritalStatus {
    single
    married
    divorced
    other
}

enum Role {
  user
  admin
  staff
}

model User { 
  id            String          @id @default(uuid()) 
  email         String?  @unique
  first_name    String?
  last_name     String?
  username      String?   @unique
  phone_number  String?         @unique
  gender        genderStatus?
  marital_status maritalStatus?
  role            Role          @default(user)
  active         Boolean        @default(true)
  password      String

  last_login    DateTime?
  date_joined   DateTime        @default(now())

  updatedProducts  Product[] @relation("UpdatedProducts")
  approvedProducts Product[] @relation("ApprovedProducts")
  cartItems        Cart[]    @relation("CartUser")
  orders           Order[]   @relation("OrderUser")
  invoices         ProductInvoice[] @relation("InvoiceUser")
}


enum productStatus {
  approved
  pending
  rejected
  review
}

model Product {
  id            String      @id   @default(uuid())
  name          String?     
  price         Decimal     @db.Decimal(10, 2)
  newPrice      Decimal?     @db.Decimal(10, 2)
  description   String?
  quantity      Int         @default(0)
  draft         Boolean     @default(true)
  approved      productStatus     @default(pending)
  categoryId    String
  category      ProductCategory   @relation(fields: [categoryId], references: [id])

  updatedById   String?
  updatedBy     User? @relation("UpdatedProducts", fields: [updatedById], references: [id])

  approvedById  String?
  approvedBy    User? @relation("ApprovedProducts", fields: [approvedById], references: [id])

  photo         String?

  descriptions  ProductDescription[] @relation("Product")

  last_updated  DateTime?
  createdAt     DateTime    @default(now())

  carts         Cart[]  @relation("cartProducts")

  @@index([categoryId])

}

model ProductCategory {
  id          String    @id   @default(uuid())
  category    String?   @unique

  createdAt   DateTime  @default(now())

  products   Product[]
}

model ProductDescription {
  id          String    @id   @default(uuid())
  photo       String[]
  productId   String
  product     Product   @relation("Product", fields: [productId], references: [id])
  description String?
  createdAt   DateTime  @default(now())
}

model Cart {
  id          String    @id   @default(uuid())
  productId   String
  product     Product  @relation("cartProducts", fields: [productId], references: [id])

  userId       String
  user         User      @relation("CartUser", fields: [userId], references: [id])

  checked     Boolean   @default(false)

  orderId      String?
  order        Order?      @relation("cartOrder", fields: [orderId], references: [id])
  quantity     Int      @default(1)
  price        Decimal  @db.Decimal(10, 2)
  total_price  Decimal  @db.Decimal(10,2)
  createdAt    DateTime   @default(now())
  invoices     ProductInvoice[] @relation("InvoiceCart")

  @@index([userId])
  @@index([orderId])
  @@index([productId])
}


enum orderStatus {
  pending
  processing
  successful
  failed
}

model Order {
  id          String  @id     @default(uuid())
  orderedUserId  String
  user        User   @relation("OrderUser", fields: [orderedUserId], references: [id])

  purchased    Boolean  @default(false)
  total_price  Decimal  @db.Decimal(10,2)
  txRef        String?
  status       orderStatus? @default(pending)
  orderedDate  DateTime @default(now())

  carts        Cart[]   @relation("cartOrder")

  @@index([orderedUserId])
}

model ProductInvoice {
  id        String    @id   @default(uuid())
  invoiceUserId String
  user      User      @relation("InvoiceUser", fields: [invoiceUserId], references: [id])
  cartId    String
  cart      Cart       @relation("InvoiceCart", fields: [cartId], references: [id])
  productPrice  Decimal  @db.Decimal(10,2)

  @@index([invoiceUserId])
  @@index([cartId])
}